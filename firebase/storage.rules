rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User profile photos
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Merchant photos (cover, profile)
    match /businesses/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Menu photos — solo el comercio propietario puede escribir en su carpeta
    match /dailyOffers/{merchantId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == merchantId;
    }
  }
}
