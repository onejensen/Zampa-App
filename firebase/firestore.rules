rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──
    function isAuth() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isMerchant() {
      return isAuth() && getUserRole() == 'COMERCIO';
    }
    function merchantPlanTier(uid) {
      return get(/databases/$(database)/documents/businesses/$(uid)).data.planTier;
    }
    function isMerchantProUser(uid) {
      return merchantPlanTier(uid) == 'pro';
    }
    /**
     * ¿El comercio está verificado? Ausente o `true` cuenta como verificado para
     * mantener compat con docs legacy. Sólo `false` explícito significa pendiente.
     */
    function isMerchantVerifiedUser(uid) {
      return get(/databases/$(database)/documents/businesses/$(uid)).data.get('isVerified', true) == true;
    }

    /**
     * Promo global: si `config/promo.freeUntil` (ms epoch) > now, todos los
     * merchants se consideran activos sin importar su estado individual.
     * Pensado para periodos de lanzamiento con gratuidad general. El admin
     * cambia la fecha directamente desde Firebase Console.
     */
    function isPromoActive() {
      return exists(/databases/$(database)/documents/config/promo)
        && get(/databases/$(database)/documents/config/promo).data.get('freeUntil', 0) > request.time.toMillis();
    }

    /**
     * ¿El merchant tiene suscripción vigente (trial no expirado o pago activo)?
     * - `trial`: trialEndsAt > now
     * - `active`: subscriptionActiveUntil > now
     * - `expired` o status ausente legacy: aplicamos gracia vía `trialEndsAt`
     * - Promo global activa: siempre true.
     *
     * Los valores de timestamp se guardan como ms epoch (Int) para ser
     * interoperables entre iOS/Android. Firestore compara Int con Int.
     */
    function hasActiveSubscription(uid) {
      let biz = get(/databases/$(database)/documents/businesses/$(uid)).data;
      let status = biz.get('subscriptionStatus', 'trial');
      let nowMs = request.time.toMillis();
      return isPromoActive()
          || (status == 'trial' && biz.get('trialEndsAt', 0) > nowMs)
          || (status == 'active' && biz.get('subscriptionActiveUntil', 0) > nowMs);
    }
    function unchanged(field) {
      return !(field in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ── Users ──
    // Privacy: solo el dueño puede leer su propio doc (email/teléfono no son públicos).
    // Para mostrar el nombre/avatar del comercio en el feed se usa /businesses (público).
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      // Update permitido sólo al dueño. No se puede auto-elevar el rol.
      // Además, el flow de eliminación de cuenta limita qué updates son válidos
      // dependiendo del estado actual del doc:
      //   - Solicitar eliminación: setea deletedAt y scheduledPurgeAt (ambos timestamp)
      //   - Recuperar cuenta: ambos campos deben quedar ausentes tras el write
      //   - Escritura normal: sólo si la cuenta está activa (deletedAt no presente / null)
      allow update: if isOwner(userId)
        && unchanged('role')
        && (
          (request.resource.data.deletedAt is timestamp
            && request.resource.data.scheduledPurgeAt is timestamp)
          ||
          (!('deletedAt' in request.resource.data)
            && !('scheduledPurgeAt' in request.resource.data))
          ||
          (!('deletedAt' in resource.data) || resource.data.deletedAt == null)
        )
        && (!('currencyPreference' in request.resource.data)
            || request.resource.data.currencyPreference in
               ['EUR','USD','GBP','JPY','CHF','SEK','NOK','DKK','CAD','AUD']);
      // Las cuentas NO se borran desde el cliente: sólo la Cloud Function
      // purgeDeletedAccounts lo hace con credenciales de admin (que bypasan rules).
      allow delete: if false;
    }

    // ── Merchant Profiles ──
    // NIF/CIF validado cliente-side antes de enviar (ver TaxIdValidator.kt/swift).
    // Server-side exigimos solo forma razonable: 9 caracteres alfanuméricos mayúsculos.
    function isValidTaxIdShape(value) {
      return value is string && value.size() == 9 && value.matches('^[A-Z0-9]{9}$');
    }
    match /businesses/{merchantId} {
      allow read: if true; // Perfiles públicos
      allow create: if isOwner(merchantId) && isMerchant()
        // El cliente nunca puede crearse como pro/destacado/verificado
        && (!('planTier' in request.resource.data) || request.resource.data.planTier == 'free')
        && (!('isHighlighted' in request.resource.data) || request.resource.data.isHighlighted == false)
        && (!('isVerified' in request.resource.data) || request.resource.data.isVerified == false)
        && (!('taxId' in request.resource.data) || isValidTaxIdShape(request.resource.data.taxId));
      allow update: if isOwner(merchantId)
        // planTier, isHighlighted e isVerified solo los modifica backend (Cloud Function /
        // admin desde Firebase Console tras revisar pendingVerifications)
        && unchanged('planTier')
        && unchanged('isHighlighted')
        && unchanged('isVerified')
        // subscriptionStatus / subscriptionActiveUntil solo los actualizan
        // las Cloud Functions appStoreNotifications / playRTDN.
        && unchanged('subscriptionStatus')
        && unchanged('subscriptionActiveUntil')
        && (!('taxId' in request.resource.data) || isValidTaxIdShape(request.resource.data.taxId))
        // appAccountToken: UUID generado por la app antes de la primera compra.
        // Sólo se permite asignarlo una vez (de ausente a string); no editarlo después.
        && (!('appAccountToken' in request.resource.data)
            || (request.resource.data.appAccountToken is string
                && (!('appAccountToken' in resource.data)
                    || resource.data.appAccountToken == request.resource.data.appAccountToken)));
      allow delete: if false;
    }

    // ── Pending Verifications ──
    // Cola de comercios pendientes de verificación manual. La crea la Cloud Function
    // `onBusinessCreated` cuando un nuevo merchant se registra. El admin la consulta
    // y la borra desde Firebase Console (o vía herramientas admin) tras flippear
    // `businesses/{id}.isVerified = true`. Los clientes nunca acceden a esta colección.
    match /pendingVerifications/{merchantId} {
      allow read, write: if false; // Solo backend (Cloud Functions / admin SDK)
    }

    // ── Customer Profiles ──
    match /customers/{customerId} {
      allow read: if isOwner(customerId);
      allow create: if isOwner(customerId);
      allow update: if isOwner(customerId);
      allow delete: if false;
    }

    // ── Daily Offers ──
    match /dailyOffers/{menuId} {
      allow read: if true; // Feed público
      // Validamos isMerchantPro server-side leyendo el doc del comercio.
      // Además: el merchant necesita suscripción vigente (trial o pago) para crear.
      // Sin suscripción activa se bloquean NUEVAS ofertas; las existentes expiran
      // naturalmente a las 24h vía Cloud Function `expireMenus`.
      allow create: if isMerchant()
        && hasActiveSubscription(request.auth.uid)
        && request.resource.data.businessId == request.auth.uid
        && request.resource.data.isMerchantPro == isMerchantProUser(request.auth.uid)
        // isMerchantVerified debe coincidir con el flag del comercio (no permitimos
        // spoof desde el cliente). Si no está presente, no se valida (legacy / migración).
        && (!('isMerchantVerified' in request.resource.data)
            || request.resource.data.isMerchantVerified == isMerchantVerifiedUser(request.auth.uid));
      allow update: if isAuth()
        && resource.data.businessId == request.auth.uid
        && request.resource.data.businessId == request.auth.uid
        && request.resource.data.isMerchantPro == isMerchantProUser(request.auth.uid)
        && (!('isMerchantVerified' in request.resource.data)
            || request.resource.data.isMerchantVerified == isMerchantVerifiedUser(request.auth.uid));
      allow delete: if isAuth() && resource.data.businessId == request.auth.uid;
    }

    // ── Favorites ──
    match /favorites/{favId} {
      allow read: if isAuth() && resource.data.customerId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.customerId == request.auth.uid;
      allow update: if isAuth() && resource.data.customerId == request.auth.uid;
      allow delete: if isAuth() && resource.data.customerId == request.auth.uid;
    }

    // ── Metrics (merchant-owned) ──
    // SOLO backend (Cloud Functions) puede escribir métricas. Los clientes invocan
    // las callable functions `trackAction` / `trackImpression` (ver functions/index.js).
    // Esto impide que un atacante autenticado infle/sabotee métricas de otro comercio.
    match /metrics/{merchantId} {
      allow read: if isOwner(merchantId);
      match /daily/{dateStr} {
        allow read: if isOwner(merchantId);
        allow write: if false;
      }
    }

    // ── Device Tokens ──
    // El usuario puede leer/escribir sólo sus propios tokens (necesario para el
    // sweep en `requestAccountDeletion` que limpia los tokens al pedir borrado).
    // Otros usuarios no pueden ver tokens ajenos: el filtro por `userId` en cualquier
    // query devuelve sólo los del propio uid, evitando exfiltración.
    match /deviceTokens/{tokenId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Notifications (in-app) ──
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if false; // Solo Cloud Functions
      allow update: if isAuth() && resource.data.userId == request.auth.uid; // Marcar como leída
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Subscriptions ──
    // Solo backend (Cloud Functions appStoreNotifications / playRTDN) puede crear/actualizar.
    match /subscriptions/{subId} {
      allow read: if isAuth() && resource.data.businessId == request.auth.uid;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // ── User History ──
    match /userHistory/{historyId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }

    // ── Cuisine Types (catálogo) ──
    match /cuisineTypes/{typeId} {
      allow read: if true; // Catálogo público
      allow write: if false; // Solo admin
    }

    // ── Config singleton docs (exchangeRates, future config entries) ──
    // Lectura pública para cualquier usuario autenticado. Sólo Cloud
    // Functions escriben (admin bypass).
    match /config/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // ── Reports ──
    match /reports/{reportId} {
      allow read: if false; // Solo admin (Cloud Functions)
      allow create: if isAuth();
      allow update, delete: if false;
    }
  }
}
