# EatOut seed scripts configuration.
# Copy this file to `.env` and fill in the values.
# `.env` is gitignored — never commit it.

# Firebase project ID (public, same as in google-services.json)
EATOUT_PROJECT_ID=eatout-70b8b

# Firebase Web API key (public, same as in google-services.json)
EATOUT_FIREBASE_API_KEY=

# Google OAuth client ID + secret used by firebase-tools to refresh access tokens.
# These are normally derived from your local firebase-tools install. The client_secret
# IS sensitive: do NOT commit it. Rotate it via:
#   https://console.cloud.google.com/apis/credentials  -> select the client -> Reset secret
EATOUT_FIREBASE_OAUTH_CLIENT_ID=
EATOUT_FIREBASE_OAUTH_CLIENT_SECRET=

# Default password for the bot test accounts. Use a long random string in any
# environment that's not strictly local development.
EATOUT_BOT_PASSWORD=
