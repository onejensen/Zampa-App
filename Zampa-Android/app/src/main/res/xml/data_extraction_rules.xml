<?xml version="1.0" encoding="utf-8"?>
<!--
  Disable cloud backups and device-to-device transfers of app data.
  EatOut auth state lives in Firebase Auth (cloud) so we don't want
  local SharedPreferences with FCM tokens or cached credentials being
  copied to other devices.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
